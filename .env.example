# Immich API Key — generate one at Immich Web → User Settings → API Keys
# config.yml immich.api_key takes precedence; this is the fallback
IMMICH_API_KEY=your_immich_api_key_here

# Telegram Bot API Server (local mode) credentials
# Get these at https://my.telegram.org
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
